-# locals: (f:, table: false)

- if table
  %div{ class: 'basis-1/5' }
    = f.number_field :week, min: 1, max: 52, class: 'text-center w-10'
  %div{ class: 'basis-1/5' }
    = f.select :day, CourseLesson.day_options.map { |label, value| [label[0..2], value] }
  = f.hidden_field :course_id

- else
  %div{ class: 'form-group basis-1/4' }
    = f.label :week
    = f.number_field :week,
                     min: 1, max: 52,
                     data: { action: 'course-dates#calculateDate',
                             'course-dates-target': 'week' }

  %div{ class: 'form-group basis-1/4' }
    = f.label :day
    = f.select :day,
               CourseLesson.day_options(include_shortcuts: true),
               {},
               data: { action: 'course-dates#calculateDate',
                       'course-dates-target': 'day' }
