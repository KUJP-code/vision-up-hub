-# locals: (teacher_tool:)

= form_with model: teacher_tool,
            html: { class: 'form',
                    data: { controller: 'teacher-tool-form' } } do |f|
  = render 'shared/form_errors', resource: teacher_tool

  = hidden_field_tag :organisation_id, params[:organisation_id]

  .form-group
    = f.label :title
    = f.text_field :title, required: true

  .form-group
    = f.label :description
    = f.text_area :description

  .form-group
    = f.label :cover_image, 'Picture'
    %small Best with a square image, like tutorial cards.
    = f.file_field :cover_image, accept: 'image/png,image/jpeg,image/webp'

  .grid.grid-cols-1.md:grid-cols-2.gap-3
    .form-group
      = f.label :kind, 'Type'
      = f.select :kind,
                 TeacherTool.kinds.keys.map { |kind| [kind == 'video' ? 'Video' : 'Other', kind] },
                 {},
                 { required: true,
                   data: { 'teacher-tool-form-target': 'kindSelect',
                           action: 'change->teacher-tool-form#toggle' } }

    .form-group
      = f.label :duration_label
      = f.text_field :duration_label, placeholder: '2 min'

  .form-group{ data: { 'teacher-tool-form-target': 'videoField' } }
    = f.label :video_path, 'Video Link'
    %small Paste a YouTube or Vimeo link. It will be converted for the modal automatically.
    = f.url_field :video_path

  .form-group{ data: { 'teacher-tool-form-target': 'externalField' } }
    = f.label :url, 'Link'
    %small Use this for normal links that should open in a new tab.
    = f.url_field :url

  .grid.grid-cols-1.md:grid-cols-2.gap-3
    .form-group
      = f.label :position
      = f.number_field :position, min: 0

    .form-check.self-end
      = f.check_box :active
      = f.label :active

  = f.submit class: 'btn btn-main self-center'
