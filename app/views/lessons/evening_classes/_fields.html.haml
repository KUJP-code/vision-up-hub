-# locals: (f:, lesson:)

:ruby
  subtype_options = (EveningClass::KEEP_UP_SUBTYPES + EveningClass::SPECIALIST_SUBTYPES).map do |key|
    [
      t("lessons.subtypes.#{key}"),
      key,
      { data: { levels: EveningClass.levels_for_subtype(key).join(',') } }
    ]
  end

.form-group{ data: { fields_target: 'eveningSubtypeField' } }
  = f.label :subtype
  = f.select :subtype,
             subtype_options,
             { prompt: 'Select a subtype' },
             { data: { fields_target: 'subtypeSelect' } }

.flex.flex-col.gap-4{ data: { fields_target: 'specialistSubtypeFields' }, style: (lesson.specialist_structured? ? nil : 'display:none;') }
  - EveningClass::SPECIALIST_SUBTYPES.each do |subtype|
    .border.border-secondary-50.rounded.p-4.flex.flex-col.gap-3
      %h3.text-lg.font-semibold= t("lessons.subtypes.#{subtype}")
      .form-group
        = f.label :"#{subtype}_goal", t('goal')
        = f.text_area :"#{subtype}_goal", rows: 1, style: 'min-height: 2.75rem;'

      .form-group
        = f.label :"#{subtype}_resources", t('resources')
        = f.file_field :"#{subtype}_resources", multiple: true
        = render 'lessons/shared/editable_resource_list',
                 f:,
                 resources: lesson.public_send("#{subtype}_resources_attachments").includes(:blob),
                 attachment_name: :"#{subtype}_resources"
