= render 'shared/subtitle', text: "Change another user's password"

%main.p-3{"data-controller" => "password-change-mode"}
  = hidden_field_tag :password_change_mode, 'single', data: { 'password-change-mode-target': 'input' }

  %details.dropdown.bg-secondary.text-white.mb-4{ id: 'password_change_mode_menu',
                                                  data: { 'password-change-mode-target': 'menu' } }
    %summary.font-semibold.p-2
      %span Password change mode:
      = succeed '' do
        %span{ data: { 'password-change-mode-target': 'label' } } Change one password
    %nav.dropdown-nav
      %button.dropdown-item.w-full.text-left{ type: 'button',
                                              data: { action: 'password-change-mode#setMode',
                                                      mode: 'single',
                                                      label: 'Change one password' } }
        Change one password
      - if current_user.is?('Admin')
        %button.dropdown-item.w-full.text-left{ type: 'button',
                                                data: { action: 'password-change-mode#setMode',
                                                        mode: 'ku_teachers',
                                                        label: 'Change KidsUP Teachers' } }
          Change KidsUP Teachers
        %button.dropdown-item.w-full.text-left{ type: 'button',
                                                data: { action: 'password-change-mode#setMode',
                                                        mode: 'ku_managers',
                                                        label: 'Change KidsUP Managers' } }
          Change KidsUP Managers

  .mt-4{ "data-mode" => "single", "data-password-change-mode-target" => "panel" }
    = form_with url: admin_change_password_path, local: true, html: { class: 'form' } do |f|
      .form-group
        = f.label :email
        = f.email_field :email

      .form-group
        = f.label :new_password
        = f.password_field :new_password,
                           minlength: 10,
                           required: true,
                           title: 'Password must be at least 10 characters and include uppercase, lowercase, and a number'
        %small At least 10 characters, with uppercase, lowercase, and a number

      .form-group
        = f.label :confirm_new_password
        = f.password_field :confirm_new_password,
                           minlength: 10,
                           required: true,
                           title: 'Password must be at least 10 characters and include uppercase, lowercase, and a number'

      = f.submit 'Change Password', class: 'btn btn-main'

  - if current_user.is?('Admin')
    .mt-4.hidden{ "data-mode" => "ku_teachers", "data-password-change-mode-target" => "panel" }
      = form_with url: admin_change_password_path, local: true, html: { class: 'form' } do |f|
        = f.hidden_field :target_group, value: 'ku_teachers'

        .form-group
          %label KidsUP teachers
          %small #{@ku_teacher_count} account(s) will be updated

        .form-group
          = label_tag :ku_teachers_new_password, 'New password'
          = password_field_tag :new_password, nil,
                               id: 'ku_teachers_new_password',
                               minlength: 10,
                               required: true,
                               title: 'Password must be at least 10 characters and include uppercase, lowercase, and a number'
          %small At least 10 characters, with uppercase, lowercase, and a number

        .form-group
          = label_tag :ku_teachers_confirm_new_password, 'Confirm new password'
          = password_field_tag :confirm_new_password, nil,
                               id: 'ku_teachers_confirm_new_password',
                               minlength: 10,
                               required: true,
                               title: 'Password must be at least 10 characters and include uppercase, lowercase, and a number'

        = f.submit 'Change All KidsUP Teacher Passwords', class: 'btn btn-main'

    .mt-4.hidden{ "data-mode" => "ku_managers", "data-password-change-mode-target" => "panel" }
      = form_with url: admin_change_password_path, local: true, html: { class: 'form' } do |f|
        = f.hidden_field :target_group, value: 'ku_managers'

        .form-group
          %label KidsUP managers
          %small #{@ku_manager_count} account(s) will be updated

        .form-group
          = label_tag :ku_managers_new_password, 'New password'
          = password_field_tag :new_password, nil,
                               id: 'ku_managers_new_password',
                               minlength: 10,
                               required: true,
                               title: 'Password must be at least 10 characters and include uppercase, lowercase, and a number'
          %small At least 10 characters, with uppercase, lowercase, and a number

        .form-group
          = label_tag :ku_managers_confirm_new_password, 'Confirm new password'
          = password_field_tag :confirm_new_password, nil,
                               id: 'ku_managers_confirm_new_password',
                               minlength: 10,
                               required: true,
                               title: 'Password must be at least 10 characters and include uppercase, lowercase, and a number'

        = f.submit 'Change All KidsUP Manager Passwords', class: 'btn btn-main'
