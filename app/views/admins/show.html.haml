= render 'shared/subtitle', text: "Yo, #{@user.name}"

%main.flex.flex-col.gap-3.p-3
  - if @announcements.any?
    = render 'shared/announcement_list', announcements: @announcements
  .flex.flex-wrap.justify-center.gap-3
    = render 'admins/admin_links'
    = render 'writers/curriculum_links'

  = render 'users/teacher_spy', org_teachers: @org_teachers

  = render 'admins/lesson_activity',
           assigned_lessons: @assigned_lessons,
           created_lessons: @created_lessons,
           new_proposed_changes: @new_proposed_changes,
           new_proposed_lessons: @new_proposed_lessons
