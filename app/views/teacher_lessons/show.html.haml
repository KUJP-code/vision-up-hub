:ruby
  border = "border-b-2 #{lvl_border_class(@lesson.short_level)}"
  text = lvl_text_class(@lesson.short_level)
  display_type = @specialist_subtype.present? ? t("lessons.subtypes.#{@specialist_subtype}") : lesson_type_heading(@lesson)
  display_level = @specialist_subtype.present? ? t("lessons.subtypes.#{@specialist_subtype}") : lesson_level_heading(@lesson)
  display_icon = @specialist_subtype.present? ? "lesson_types/#{@specialist_subtype}.svg" : type_icon_path(@lesson)
  display_details = @specialist_subtype.present? ? @lesson.specialist_goal_for(@specialist_subtype) : lesson_details_heading(@lesson)

= turbo_frame_tag 'lesson' do
  = render 'teacher_lessons/tabs',
           lessons: @type_lessons, active_lesson: @lesson, level: @level,
           teacher_id: @teacher.id, type: @type, date: @date

  %dialog.resources-dialog#lesson-video.video-dialog
    .body.p-4.flex.justify-center.items-center
      %form.h-0
        %button{ formmethod: :dialog }
          = image_tag 'exit.svg', class: 'btn-close'

      %iframe#lesson-video-frame{
        src: "",
        frameborder: 0,
        allow: "accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture",
        allowfullscreen: true,
        class: "w-full h-full"
      }

  .dialog-content
    %header
      %h1{ class: "type #{border}" }
        = display_type
      %h1{ class: "level #{text} #{border}" }
        = display_level
      = image_tag display_icon, class: 'h-full place-self-end'
      %h3.details= display_details

    - if @lesson.guide.attached?
      = render 'teacher_lessons/guide_section',
               lesson: @lesson

    - if @resources.any?
      = render 'teacher_lessons/resources_section',
               resources: @resources

    - if @lesson_links.any?
      = render 'teacher_lessons/links_section',
               lesson_links: @lesson_links
